{
  "name": "@canaryctl/core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && cp -R migrations dist/migrations",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "CANARY_HOME=/tmp/canary-test-home vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "kysely": "^0.28.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
