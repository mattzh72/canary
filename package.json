{
  "name": "canary-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Canary monorepo for the runtime wrapper, review CLI, and agent skills.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter canaryctl dev",
    "install:local": "pnpm build && node scripts/install-local.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.20.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vitest": "^3.0.8"
  },
  "packageManager": "pnpm@10.31.0"
}
